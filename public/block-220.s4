; Block.220

1`BL
N"Count of primes"

; c:              Register for count of primes
; P: (n l--f)     Is Prime Number routine
; Q: (n1--n2)     Count of Primes routine
; B: (n--)        Benchmark routine
; L: (n--)        Loop for multiple benchmarks

:P`O`O`/0=($$=;)`O<($$;)2+P;
:Q 4c! 11[i@3P(c`#)i`#]c@;
:B N"# primes in "#." - "`T`S Q.`T`S- " (" . " ms)";
:L 256 `S 1[#+#B]\;

10 L
